        "CLOUD_SQL_POSTGRES_REGION": "${CLOUD_SQL_POSTGRES_REGION}",
        "CLOUD_SQL_POSTGRES_INSTANCE": "${CLOUD_SQL_POSTGRES_INSTANCE}",
        "CLOUD_SQL_POSTGRES_DATABASE": "${CLOUD_SQL_POSTGRES_DATABASE}",
