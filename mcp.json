      "description": "Use these skills when you need to troubleshoot performance bottlenecks, analyze query execution plans, identify resource-heavy processes, and monitor system-level PromQL metrics.",
      "allowedTools": [
        "get_query_metrics",
        "get_query_plan",
        "get_system_metrics",
        "list_active_queries",
        "list_database_stats",
        "list_locks",
        "list_query_stats",
